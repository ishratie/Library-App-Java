<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="740.0" prefWidth="1260.0" spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fi.jyu.ohj2.iliadanilo.kirjasto.project.KirjaListaController">
    <padding>
        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
    </padding>
    <children>
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <children>
                <Label text="Kirjasto">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#avaaMyohastyneet" text="Myöhästyneet" />
                <Button mnemonicParsing="false" onAction="#avaaLisaaKirja" text="Lisää kirja" />
            </children>
        </HBox>
        <TableView fx:id="kirjaTablu" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="nimiKolumni" prefWidth="180.0" text="Nimi" />
                <TableColumn fx:id="tekijaKolumni" prefWidth="150.0" text="Tekijä" />
                <TableColumn fx:id="isbnKolumni" prefWidth="140.0" text="ISBN" />
                <TableColumn fx:id="tilanneKolumni" prefWidth="100.0" text="Tilanne" />
                <TableColumn fx:id="lainattuKolumni" prefWidth="110.0" text="Lainattu kertaa" />
                <TableColumn fx:id="toiminnotKolumni" prefWidth="200.0" text="Toiminnot" />
            </columns>
        </TableView>
    </children>
</VBox>
