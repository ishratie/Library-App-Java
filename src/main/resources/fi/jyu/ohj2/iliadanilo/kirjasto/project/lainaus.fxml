<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefWidth="350.0" spacing="12.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fi.jyu.ohj2.iliadanilo.kirjasto.project.LainausController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <Label text="Lainaa kirja">
            <font>
                <Font name="System Bold" size="16.0" />
            </font>
        </Label>
        <Label text="Lainaajan nimi" />
        <TextField fx:id="lainaajaField" maxWidth="1.7976931348623157E308" promptText="Etu- ja sukunimi" />
        <Label text="Palautuspäivä" />
        <DatePicker fx:id="palautusPvmPicker" maxWidth="1.7976931348623157E308" />
        <Label fx:id="virheLabel" style="-fx-text-fill: red;" text="" />
        <HBox alignment="CENTER_RIGHT" spacing="8.0">
            <children>
                <Button mnemonicParsing="false" onAction="#sulje" text="Peruuta" />
                <Button mnemonicParsing="false" onAction="#lainaa" text="Lainaa" />
            </children>
        </HBox>
    </children>
</VBox>
